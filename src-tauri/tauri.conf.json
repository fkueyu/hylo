{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hylo",
  "version": "0.1.2",
  "identifier": "com.ainx.hylo.editor.v2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hylo",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "maximized": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI4RDg2M0VGRDhEN0Q3MUMKUldRYzE5Zlk3MlBZS0ZsSU03Q1hBYVJNNldaNGpEek1LMjVXcm9rUUU0b1BiS1V2T1BrTnRuTlMK",
      "endpoints": [
        "https://ainx.ink/hylo/updater.json"
      ]
    }
  }
}

